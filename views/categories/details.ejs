<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/output.css">
    <title><%= title %></title>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="mx-3 flex justify-between items-center mb-15">
        <div class="flex flex-col gap-5">
            <h1 class="text-3xl font-bold bg-amber-200 rounded inline-block py-3 px-4">Category Name: <span class="font-semibold"><%= category.name %></span></h1>
            <p class="text-2xl font-semibold">Description: <span class="font-normal"><%= category.description %></span> </p>
        </div>
        <div class="actions flex flex-col items-center justify-center gap-3">
        <!-- <a href="/categories/<%= category.id %>/edit">Edit Category</a> -->
            
            <form action="/categories/<%= category.id %>/delete" method="POST" style="display:inline;">
                <button class="px-3 py-4 text-sm bg-red-500 rounded-4xl text-white font-bold" type="submit" onclick="return confirm('Are you absolutely sure you want to delete this category? All items inside it will be affected.');">
                    Delete Category
                </button>
            </form>
            <p class="font-normal italic"> Note: Must delete all the items before Deleting the category</p>
        </div>

    </div>

    

    <div class="mx-auto">
        <div class="flex justify-center items-center mb-5">
            <h2 class="text-4xl font-extrabold ">Items in this category:</h2>
        </div>
        <ul class="grid grid-cols-3 mx-auto text-2xl font-normal gap-10 p-5 ">
            <% items.forEach(item => { %>
                <li class="flex justify-center text-white hover:text-blue-400 bg-orange-400 p-10 rounded-4xl">
                    <a href="/items/<%= item.id %>">
                        <%= item.name %>
                    </a>
                </li>
            <% }); %>
        </ul>
    </div>
</body>
</html>