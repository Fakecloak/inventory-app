<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/output.css">
    <title><%= title %></title>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class=" flex flex-col justify-center items-center gap-5 mx-auto mb-5">
        <h1 class="text-3xl font-bold bg-amber-200 rounded inline-block py-3 px-4">Category Name: <span class="font-semibold"><%= category.name %></span></h1>
        <p class="text-2xl">Description: <span class="font-semibold"><%= category.description %></span> </p>

        <div class="actions flex flex-col items-center justify-center gap-3">
        <!-- <a href="/categories/<%= category.id %>/edit">Edit Category</a> -->
            
            <form action="/categories/<%= category.id %>/delete" method="POST" style="display:inline;">
                <button class="px-3 py-4 text-2xl bg-red-500 rounded-4xl text-white font-bold" type="submit" onclick="return confirm('Are you absolutely sure you want to delete this category? All items inside it will be affected.');">
                    Delete Category
                </button>
            </form>
            <p class="font-normal italic"> Note: Must delete all the items before Deleting the category</p>
        </div>

    </div>

    


    <h2>Items in this category:</h2>
    <ul>
        <% items.forEach(item => { %>
            <li>
                <a href="/items/<%= item.id %>">
                    <%= item.name %>
                </a>
            </li>
        <% }); %>
    </ul>
</body>
</html>