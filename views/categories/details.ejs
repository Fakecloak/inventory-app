<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
</head>
<body>
    <%- include('../partials/navbar') %>
    <h1><%= category.name %></h1>
    <p><%= category.description %></p>

    <h2>Items in this category:</h2>
    <ul>
        <% items.forEach(item => { %>
            <li>
                <a href="/items/<%= item.id %>">
                    <%= item.name %>
                </a>
            </li>
        <% }); %>
    </ul>
</body>
</html>