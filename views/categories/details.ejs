<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
</head>
<body>
    <%- include('../partials/navbar') %>
    <h1><%= category.name %></h1>
    <p><%= category.description %></p>

    <div class="actions">
        <!-- <a href="/categories/<%= category.id %>/edit">Edit Category</a> -->
            
        <form action="/categories/<%= category.id %>/delete" method="POST" style="display:inline;">
            <button type="submit" onclick="return confirm('Are you absolutely sure you want to delete this category? All items inside it will be affected.');">
                Delete Category
            </button>
        </form>
    </div>


    <h2>Items in this category:</h2>
    <ul>
        <% items.forEach(item => { %>
            <li>
                <a href="/items/<%= item.id %>">
                    <%= item.name %>
                </a>
            </li>
        <% }); %>
    </ul>
</body>
</html>