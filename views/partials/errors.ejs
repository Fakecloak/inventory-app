<% if (locals.errors && errors.length > 0) { %>
    <div class="error-container" style="background-color: #ffe6e6; border-left: 5px solid red; padding: 10px; margin-bottom: 15px;">
        <ul style="color: red; margin: 0; padding-left: 20px;">
            <% errors.forEach(function(error) { %>
                <li><%= error.msg %></li>
            <% }) %>
        </ul>
    </div>
<% } %>