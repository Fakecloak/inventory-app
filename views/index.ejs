<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home Page | Inventory App</title>
</head>
<body>
    <h1> <%= title %></h1>
    <ul>
        <% categories.forEach(category => {%>
            <li>
                <a href='/categories/<%= category.id %>''>
                   <%= category.name %> 
                </a>
            </li>
            <% }) %>
    </ul>
    
</body>
</html>