<%- include('partials/head', { title: `${title} | Inventory App` }) %>

<%- include('partials/navbar') %>

    <h1 class="text-4xl font-bold text-blue-500 mx-auto text-center mb-5" > <%= title %></h1>
    <ul class="mx-auto text-2xl font-normal grid grid-cols-3 gap-10 p-5 ">
        <% categories.forEach(category => {%>
            <li class="flex justify-center  hover:text-blue-400 ">
                <a  href='/categories/<%= category.id %>''>
                   <%= category.name %> 
                </a>
            </li>
            <% }) %>
    </ul>
    
<%- include('partials/footer') %>