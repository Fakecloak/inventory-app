<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/output.css">
    <title><%= title %></title>
</head>
<body>
    <%- include('../partials/navbar') %>
    <h1 class="text-center mx-auto font-bold text-4xl mb-5"><%= item.name %></h1>
    <div class="flex flex-col justify-center items-center mb-20">
        <ul class="space-y-6">
            <p class="font-normal text-2xl mb-5">Description: <span class="font-normal text-xl"><%= item.description %></span></p>
            <li class="font-normal text-2xl">Item Manufacturer: <span class="font-normal text-xl"><%= item.manufacturer %></span></li>
            <li class="font-normal text-2xl">Item Price: <span class="font-normal text-xl"><%= item.price %></span></li>
            <li class="font-normal text-2xl">Item Quantity: <span class="font-normal text-xl"><%= item.stock_quantity %></span></li>
            
            <li class="font-normal text-2xl">Category: <span class="font-normal text-xl"><%= item.category_name %></span></li>
        </ul>
    </div>

    <div class="actions flex justify-center  ">
  

        <form action=""></form>

            
        <form action="/items/<%= item.id %>/delete" method="POST" style="display:inline;">
            <button class="rounded-4xl bg-red-500 p-4 text-white font-normal"
            type="submit" onclick="return confirm('Are you absolutely sure you want to delete this category? All items inside it will be affected.');">
                Delete Item
            </button>
        </form>
    </div>

</body>
</html>