<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
</head>
<body>
    <%- include('../partials/navbar') %>
    <h1><%= item.name %></h1>
    <p><%= item.description %></p>
    <ul>
        <li><%= item.manufacturer %></li>
        <li><%= item.price %></li>
        <li><%= item.stock_quantity %></li>
        
        <li>Category: <strong><%= item.category_name %></strong></li>
    </ul>

    <div class="actions">
        <!-- <a href="/items/<%= item.id %>/edit">Edit Category</a> -->

        <form action=""></form>

            
        <form action="/items/<%= item.id %>/delete" method="POST" style="display:inline;">
            <button type="submit" onclick="return confirm('Are you absolutely sure you want to delete this category? All items inside it will be affected.');">
                Delete Item
            </button>
        </form>
    </div>

</body>
</html>